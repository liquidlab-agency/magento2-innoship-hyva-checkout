/** @var OrderViewAccount $block */
/** @var Escaper $escaper */
/** @var ViewModelRegistry $viewModels */

/** @var PudoInfo $pudoViewModel */
$pudoViewModel = $block->getPudoInfoViewModel();
$order = $block->getOrder();

if (!$order || !$pudoViewModel) {
    return;
}

$shippingAddress = $order->getShippingAddress();
if (!$shippingAddress) {
    return;
}

$pudoId = (int)$shippingAddress->getInnoshipPudoId();
if ($pudoId <= 0) {
    return;
}

$pudo = $pudoViewModel->getPudoData($pudoId);
if (!$pudo) {
    return;
}

$hyvaCsp = $viewModels->require(HyvaCsp::class);
$googleUrl = 'https://www.google.com/maps/dir/?api=1&travelmode=driving&layer=traffic&destination=';
$wazeUrl = 'https://waze.com/ul?ll=';
?>

