<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!--
        Disable InnoShip_InnoShip frontend controllers that only exist for
        the Luma checkout JS (view/frontend/web/js/checkout.js). Hyvä
        checkout is server-rendered through Magewire and never calls these
        endpoints, so they are dead URLs and are 404'd by the stub.
    -->
    <preference for="InnoShip\InnoShip\Controller\Pudo\Getpudo"
                type="Liquidlab\InnoShipHyva\Controller\Disabled\NotFound"/>
    <preference for="InnoShip\InnoShip\Controller\Pudo\Getmap"
                type="Liquidlab\InnoShipHyva\Controller\Disabled\NotFound"/>
    <preference for="InnoShip\InnoShip\Controller\Pudo\Setpudo"
                type="Liquidlab\InnoShipHyva\Controller\Disabled\NotFound"/>
    <preference for="InnoShip\InnoShip\Controller\Pudo\GetPudoFromLocation"
                type="Liquidlab\InnoShipHyva\Controller\Disabled\NotFound"/>
    <preference for="InnoShip\InnoShip\Controller\Courier\Listcouriers"
                type="Liquidlab\InnoShipHyva\Controller\Disabled\NotFound"/>
    <preference for="InnoShip\InnoShip\Controller\Courier\Setcourierid"
                type="Liquidlab\InnoShipHyva\Controller\Disabled\NotFound"/>

    <type name="Hyva\CompatModuleFallback\Model\CompatModuleRegistry">
        <arguments>
            <argument name="compatModules" xsi:type="array">
                <item name="hyva-magento2-innoship" xsi:type="array">
                    <item name="original_module" xsi:type="string">InnoShip_InnoShip</item>
                    <item name="compat_module" xsi:type="string">Liquidlab_InnoShipHyva</item>
                </item>
            </argument>
        </arguments>
    </type>


    <!--
        Per-shipping-carrier payment-method restriction.

        Disable the upstream plugin (`InnoShip\InnoShip\Plugin\Model\PaymentMethodAvailable`).
        It is brittle (hardcoded `=== "innoshipcargusgo_innoshipcargusgo_1"`)
        and strips every payment method when its admin field is empty. See
        docs/UPSTREAM_AUDIT.md item #6 for the full diagnosis.

        Our replacement reads the SAME admin field upstream already exposes
        (`carriers/innoshipcargusgo/innoship_cargus_go_payment_restriction`),
        no new admin UI, no merchant reconfiguration, but with robust
        carrier-code extraction and a real empty-config guard.
    -->
    <type name="Magento\Payment\Model\MethodList">
        <plugin name="restrict_payment_on_shippingmethod" disabled="true"/>
        <plugin name="liquidlab_innoshiphyva_payment_method_restriction"
                type="Liquidlab\InnoShipHyva\Plugin\PaymentMethodRestriction"
                sortOrder="10"/>
    </type>

    <!--
        Without this, the payment list does NOT re-render when the customer
        switches shipping method via Magewire (Hyvä only listens for
        *_address_saved + coupon events). A full page reload fixes it,
        which is why the restriction "works after refresh" but not in-flight.

        We append `shipping_method_selected` to the payment-list listener
        map so refresh fires immediately after every shipping-method change.
    -->
    <type name="Hyva\Checkout\Magewire\Checkout\Payment\MethodList">
        <plugin name="liquidlab_innoshiphyva_refresh_payment_on_shipping_change"
                type="Liquidlab\InnoShipHyva\Plugin\HyvaCheckout\RefreshPaymentMethodsOnShippingChange"
                sortOrder="10"/>
    </type>
</config>
